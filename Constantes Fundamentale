import { useState, useEffect, useRef } from "react";

// ─── Constantes Fundamentales ─────────────────────────────────────────────
const PHI = (1 + Math.sqrt(5)) / 2;
const GOLDEN_ANGLE_DEG = 360 / (PHI * PHI);
const PHI_FRAMES = 963 / 60; // Solo para animación, sin significado físico

// ─── Motor de Interacción Simpática (corregido) ──────────────────────────
const QUBITS_DEF = [
  { id: "Q1", color: "#ff3b3b", phase: 0 },
  { id: "Q2", color: "#39ff14", phase: (2 * Math.PI) / 3 },
  { id: "Q3", color: "#00e5ff", phase: (4 * Math.PI) / 3 },
];

// Coordenadas correctas de la esfera de Bloch
function getBlochCoords(theta, phi) {
  const x = Math.sin(theta) * Math.cos(phi);
  const y = Math.sin(theta) * Math.sin(phi);
  const z = Math.cos(theta);
  return { x, y, z };
}

function getEntangledVectors(tick, cx, cy, r) {
  const baseAngle = (tick * PHI_FRAMES) % (2 * Math.PI);
  return QUBITS_DEF.map((q) => {
    const phi = (baseAngle + q.phase) % (2 * Math.PI);
    // Oscilación suave en θ para dar sensación de "danza"
    const theta = Math.PI / 2 + 0.3 * Math.sin(phi * PHI);
    const { x, y, z } = getBlochCoords(theta, phi);
    const bx = cx + r * x;
    const by = cy - r * z;    // Y hacia arriba, Z hacia abajo en pantalla
    return { ...q, bx, by, theta, phi };
  });
}

// ─── Quantum Math riguroso ────────────────────────────────────────────────
function complexMul([ar, ai], [br, bi]) { return [ar*br - ai*bi, ar*bi + ai*br]; }
function complexAdd([ar, ai], [br, bi]) { return [ar+br, ai+bi]; }
function norm([r, i]) { return Math.hypot(r, i); }

function applyRZ(state, theta) {
  const [a, b] = state;
  const cos = Math.cos(theta/2), sin = Math.sin(theta/2);
  return [complexMul(a, [cos, -sin]), complexMul(b, [cos, sin])];
}
function applyH(state) {
  const [a, b] = state;
  const s = 1 / Math.sqrt(2);
  return [
    complexAdd(complexMul(a, [s,0]), complexMul(b, [s,0])),
    complexAdd(complexMul(a, [s,0]), complexMul(b, [-s,0]))
  ];
}
// Producto interno entre dos estados (vectores columna)
function innerProd(ket1, ket2) {
  const [a1, b1] = ket1;
  const [a2, b2] = ket2;
  return complexAdd(complexMul(a1, [a2[0], -a2[1]]), complexMul(b1, [b2[0], -b2[1]]));
}
function fidelityPureMixed(idealKet, rhoMatrix) {
  // rhoMatrix = [[p00, p01_real + i p01_imag], [p10, p11]]
  // ⟨ψ|ρ|ψ⟩ = sum_ij ψ_i* ρ_ij ψ_j
  const [a, b] = idealKet;
  const term00 = a[0]*a[0] + a[1]*a[1]; // |a|^2
  const term11 = b[0]*b[0] + b[1]*b[1];
  const cross = 2 * (a[0]*b[0] + a[1]*b[1]) * rhoMatrix[0][1]; // simplificación si ρ es real
  // Cálculo completo general:
  const psi = [a, b];
  let f = 0;
  for (let i=0; i<2; i++) {
    for (let j=0; j<2; j++) {
      const conj_psi_i = [psi[i][0], -psi[i][1]];
      const rho_ij = rhoMatrix[i][j];
      const prod = complexMul(conj_psi_i, rho_ij);
      f += prod[0] * psi[j][0] - prod[1] * psi[j][1];
    }
  }
  return Math.max(0, Math.min(1, f));
}

function runSimulation(tempK, shots = 4096) {
  const thetaRad = GOLDEN_ANGLE_DEG * (Math.PI / 180);
  let ideal = [[1,0], [0,0]];
  ideal = applyRZ(ideal, thetaRad);
  ideal = applyH(ideal);
  // Probabilidades ideales
  const p0_ideal = norm(ideal[0])**2;
  const p1_ideal = 1 - p0_ideal;

  // Modelo de ruido de Pauli: probabilidad de error por shot
  // A mayor temperatura, más ruido (máx 0.5 para no destruir totalmente)
  const p_error = Math.min(0.5, tempK / 1000);
  // Matriz densidad empírica inicializada a cero
  let rho = [[0,0], [0,0]];

  for (let i = 0; i < shots; i++) {
    let state = ideal;
    // Aplicar error aleatorio con probabilidad p_error
    if (Math.random() < p_error) {
      const errType = Math.random(); // 0: X, 1: Z, 2: Y (opcional)
      if (errType < 0.33) { // X gate (bit-flip)
        state = [state[1], state[0]];
      } else if (errType < 0.66) { // Z gate (phase-flip)
        state = [state[0], complexMul(state[1], [-1,0])];
      } else { // Y gate (bit+phase)
        state = [complexMul(state[1], [0,-1]), complexMul(state[0], [0,1])];
      }
    }
    // Medición en base Z
    const prob0 = norm(state[0])**2;
    const outcome = Math.random() < prob0 ? 0 : 1;
    // Actualizar matriz densidad empírica (proyectores)
    if (outcome === 0) {
      rho[0][0] += 1;
    } else {
      rho[1][1] += 1;
    }
  }
  // Normalizar
  rho[0][0] /= shots;
  rho[1][1] /= shots;
  rho[0][1] = rho[1][0] = 0; // la matriz es diagonal (solo medimos en Z)
  // Podríamos estimar coherencias si midiéramos en otra base, pero para fidelidad basta con esto.

  const fidelity = fidelityPureMixed(ideal, rho);
  const prob0 = rho[0][0];
  const prob1 = rho[1][1];
  const counts = { "0": Math.round(prob0 * shots), "1": Math.round(prob1 * shots) };

  // Recurso estético (sin significado físico)
  const recursos = Math.max(0.5, (tempK / PHI) * 0.05);

  return {
    fidelity,
    recursos,
    counts,
    idealState: ideal,
    p0_ideal,
    p1_ideal,
    prob0,
    prob1,
    p_error,
  };
}

// ─── Entangled Bloch Sphere (con trails persistentes) ─────────────────────
function EntangledBlochSphere({ tick, idealState, trails }) {
  const CX = 110, CY = 110, R = 80;
  const TRAIL = 20;
  const vectors = getEntangledVectors(tick, CX, CY, R);

  // Actualizar trails (recibidos del padre)
  vectors.forEach((v, i) => {
    trails.current[i].push({ x: v.bx, y: v.by });
    if (trails.current[i].length > TRAIL) trails.current[i].shift();
  });

  let ibx = CX, iby = CY - R;
  if (idealState) {
    const p0 = norm(idealState[0]) ** 2;
    const th = 2 * Math.acos(Math.min(1, Math.sqrt(p0)));
    const ph = Math.atan2(idealState[0][1], idealState[0][0]) - Math.atan2(idealState[1][1], idealState[1][0]);
    ibx = CX + R * Math.sin(th) * Math.cos(ph);
    iby = CY - R * Math.cos(th);
  }

  return (
    <svg width="220" height="220" viewBox="0 0 220 220">
      <defs>
        <radialGradient id="sg" cx="38%" cy="32%">
          <stop offset="0%" stopColor="#0d2a44" />
          <stop offset="100%" stopColor="#020c18" />
        </radialGradient>
        <filter id="glow2">
          <feGaussianBlur stdDeviation="2.5" result="b" />
          <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
        </filter>
      </defs>
      <circle cx={CX} cy={CY} r={R} fill="url(#sg)" stroke="#00e5ff" strokeWidth="0.7" opacity="0.85" />
      {[0, 60, 120].map(a => (
        <ellipse key={a} cx={CX} cy={CY} rx={R} ry={R*0.3}
          fill="none" stroke="#00e5ff22" strokeWidth="0.5" strokeDasharray="2,4"
          transform={`rotate(${a} ${CX} ${CY})`} />
      ))}
      <ellipse cx={CX} cy={CY} rx={R} ry={R*0.28} fill="none" stroke="#00e5ff" strokeWidth="0.5" strokeDasharray="3,3" opacity="0.3" />
      <line x1={CX} y1={CY-R-10} x2={CX} y2={CY+R+10} stroke="#fff" strokeWidth="0.4" opacity="0.15" />
      <line x1={CX-R-10} y1={CY} x2={CX+R+10} y2={CY} stroke="#fff" strokeWidth="0.4" opacity="0.15" />
      <text x={CX+4} y={CY-R-11} fill="#c8e6f5" fontSize="9" fontFamily="monospace" opacity="0.6">|0⟩</text>
      <text x={CX+4} y={CY+R+19} fill="#c8e6f5" fontSize="9" fontFamily="monospace" opacity="0.6">|1⟩</text>
      <polygon points={vectors.map(v => `${v.bx},${v.by}`).join(" ")}
        fill="none" stroke="#ffffff22" strokeWidth="0.7" strokeDasharray="2,3" />
      {vectors.map((v, qi) => (
        <g key={v.id}>
          {trails.current[qi].map((pt, ti) => (
            <circle key={ti} cx={pt.x} cy={pt.y} r={1.5} fill={v.color} opacity={(ti/TRAIL)*0.45} />
          ))}
          <line x1={CX} y1={CY} x2={v.bx} y2={v.by} stroke={v.color} strokeWidth="1.8" opacity="0.85" filter="url(#glow2)" />
          <circle cx={v.bx} cy={v.by} r="5" fill={v.color} filter="url(#glow2)" />
          <circle cx={v.bx} cy={v.by} r="9" fill="none" stroke={v.color} strokeWidth="0.8" opacity="0.35" />
          <text x={v.bx+6} y={v.by-4} fill={v.color} fontSize="8" fontFamily="monospace">{v.id}</text>
        </g>
      ))}
      {idealState && (
        <g>
          <line x1={CX} y1={CY} x2={ibx} y2={iby} stroke="#ff6b35" strokeWidth="2.2" strokeDasharray="4,3" opacity="0.75" />
          <circle cx={ibx} cy={iby} r="4" fill="#ff6b35" opacity="0.9" />
          <text x={ibx+5} y={iby-5} fill="#ff6b35" fontSize="8" fontFamily="monospace">|ψ⟩</text>
        </g>
      )}
    </svg>
  );
}

// ─── Phase Diagram (sin cambios, solo ajuste de constantes) ───────────────
function PhaseDiagram({ tick }) {
  const CX = 70, CY = 70, R = 55;
  const vectors = QUBITS_DEF.map((q) => {
    const angle = ((tick * PHI_FRAMES + q.phase)) / PHI;
    return { ...q, angle };
  });
  return (
    <svg width="140" height="148" viewBox="0 0 140 148">
      <circle cx={CX} cy={CY} r={R} fill="#020c18" stroke="#0a2a40" strokeWidth="1" />
      {[0.33, 0.66, 1].map(f => (
        <circle key={f} cx={CX} cy={CY} r={R*f} fill="none" stroke="#0a2a40" strokeWidth="0.5" />
      ))}
      {Array.from({ length: 12 }).map((_, i) => {
        const a = (i/12)*2*Math.PI;
        return <line key={i}
          x1={CX + (R-6)*Math.cos(a)} y1={CY + (R-6)*Math.sin(a)}
          x2={CX + R*Math.cos(a)} y2={CY + R*Math.sin(a)}
          stroke="#0a3a5a" strokeWidth="0.5" />;
      })}
      {vectors.map((v) => (
        <g key={v.id}>
          <line x1={CX} y1={CY}
            x2={CX + R*0.88*Math.cos(v.angle)} y2={CY + R*0.88*Math.sin(v.angle)}
            stroke={v.color} strokeWidth="1.5" opacity="0.85" />
          <circle cx={CX + R*0.88*Math.cos(v.angle)} cy={CY + R*0.88*Math.sin(v.angle)}
            r="3.5" fill={v.color} />
        </g>
      ))}
      <circle cx={CX} cy={CY} r="2.5" fill="#fff" opacity="0.5" />
      <text x={CX} y={148} textAnchor="middle" fill="#355a70" fontSize="8" fontFamily="monospace">DANZA ARMÓNICA φ</text>
    </svg>
  );
}

// ─── Prob Bar (igual) ─────────────────────────────────────────────────────
function ProbBar({ label, value, color }) {
  return (
    <div style={{ marginBottom: 7 }}>
      <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 2 }}>
        <span style={{ fontFamily: "monospace", fontSize: 10, color: "#a0c4d8" }}>{label}</span>
        <span style={{ fontFamily: "monospace", fontSize: 10, color }}>{(value * 100).toFixed(2)}%</span>
      </div>
      <div style={{ background: "#0a1a2a", borderRadius: 3, height: 6, overflow: "hidden" }}>
        <div style={{
          width: `${Math.round(value * 100)}%`, height: "100%",
          background: `linear-gradient(90deg, ${color}77, ${color})`,
          borderRadius: 3, transition: "width 0.5s ease", boxShadow: `0 0 5px ${color}66`,
        }} />
      </div>
    </div>
  );
}

// ─── Main App ─────────────────────────────────────────────────────────────
export default function ProcesadorSoberanoV27() {
  const [tempK, setTempK] = useState(298);
  const [shots, setShots] = useState(4096);
  const [result, setResult] = useState(null);
  const [running, setRunning] = useState(false);
  const [log, setLog] = useState([]);
  const [tick, setTick] = useState(0);
  const [tab, setTab] = useState("bloch");
  const logRef = useRef(null);
  const trailsRef = useRef(QUBITS_DEF.map(() => [])); // Trails persistentes

  useEffect(() => {
    let frame;
    const loop = () => { setTick(t => t + 1); frame = requestAnimationFrame(loop); };
    frame = requestAnimationFrame(loop);
    return () => cancelAnimationFrame(frame);
  }, []);

  useEffect(() => {
    if (logRef.current) logRef.current.scrollTop = logRef.current.scrollHeight;
  }, [log]);

  function addLog(msg) {
    setLog(l => [...l.slice(-50), `[${new Date().toISOString().slice(11,23)}] ${msg}`]);
  }

  function execute() {
    setRunning(true); setLog([]);
    addLog("🔵 Inicializando ProcesadorSoberanoV27 (Física corregida)");
    addLog(`📐 Ángulo Áureo: φ² = ${(PHI*PHI).toFixed(6)} → θ = ${GOLDEN_ANGLE_DEG.toFixed(4)}°`);
    addLog(`🌡️  Temperatura: ${tempK}K  |  Shots: ${shots.toLocaleString()}`);
    addLog(`🎞️  PHI_FRAMES = 963/60 = ${PHI_FRAMES.toFixed(4)} (solo animación)`);
    setTimeout(() => {
      addLog("🔗 Motor Simpático: 3 qubits con desfase 120° en esfera de Bloch");
      addLog("⚙️  Circuito: |0⟩ → RZ(θ_áureo) → H");
      addLog(`🛡️  Ruido de Pauli: p_error = ${Math.min(0.5, tempK/1000).toFixed(4)} (dependiente de T)`);
    }, 300);
    setTimeout(() => {
      addLog(`📡 Ejecutando ${shots.toLocaleString()} shots...`);
    }, 700);
    setTimeout(() => {
      const res = runSimulation(tempK, shots);
      setResult(res);
      addLog(`✅ Simulación completada.`);
      addLog(`📊 |0⟩: ${res.counts["0"].toLocaleString()}  |  |1⟩: ${res.counts["1"].toLocaleString()}`);
      addLog(`🎯 Fidelidad cuántica: ${res.fidelity.toFixed(10)}`);
      addLog(`⚡ Consumo cohesión (estético): ${res.recursos.toFixed(4)} L`);
      addLog(`🚀 EVOLUCIÓN A V27 (física ajustada)`);
      setRunning(false);
    }, 1400);
  }

  useEffect(() => { execute(); }, []);

  const pulseOp = 0.4 + 0.6 * Math.abs(Math.sin(tick * 0.04));
  const liveVec = getEntangledVectors(tick, 0, 0, 1);

  return (
    <div style={{
      minHeight: "100vh", background: "#020c18", color: "#c8e6f5",
      fontFamily: "'Courier New', monospace", padding: "20px 12px", boxSizing: "border-box",
    }}>
      {/* Header */}
      <div style={{ textAlign: "center", marginBottom: 22 }}>
        <div style={{
          display: "inline-block", background: "linear-gradient(135deg, #00e5ff0c, #39ff140c)",
          border: "1px solid #00e5ff30", borderRadius: 12, padding: "14px 28px",
          position: "relative", overflow: "hidden",
        }}>
          <div style={{
            position: "absolute", inset: 0, pointerEvents: "none",
            background: `radial-gradient(circle at 50% 50%, #00e5ff${Math.round(pulseOp*16).toString(16).padStart(2,"0")} 0%, transparent 70%)`,
          }} />
          <div style={{ fontSize: 10, color: "#00e5ff", letterSpacing: 6, marginBottom: 4 }}>MOTOR DE INTERACCIÓN SIMPÁTICA</div>
          <div style={{ fontSize: 24, fontWeight: 900, letterSpacing: 3, color: "#fff", textShadow: "0 0 18px #00e5ff" }}>
            SOBERANO V27 (FÍSICA)
          </div>
          <div style={{ display: "flex", justifyContent: "center", gap: 18, marginTop: 6 }}>
            {QUBITS_DEF.map(q => (
              <span key={q.id} style={{ fontSize: 9, color: q.color, letterSpacing: 2, fontWeight: 700 }}>● {q.id}</span>
            ))}
            <span style={{ fontSize: 9, color: "#ff6b35", letterSpacing: 2 }}>– |ψ⟩ IDEAL</span>
          </div>
        </div>
      </div>

      <div style={{ maxWidth: 900, margin: "0 auto", display: "grid", gap: 14 }}>
        {/* Controles */}
        <div style={{ background: "#050f1e", border: "1px solid #0a2a40", borderRadius: 10, padding: 18 }}>
          <div style={{ fontSize: 10, color: "#00e5ff", letterSpacing: 3, marginBottom: 14 }}>PARÁMETROS DE CONFIGURACIÓN</div>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20 }}>
            <div>
              <label style={{ fontSize: 10, color: "#6a9ab0", display: "block", marginBottom: 6 }}>
                TEMPERATURA: <span style={{ color: "#00e5ff" }}>{tempK}K</span>
              </label>
              <input type="range" min="77" max="500" value={tempK} onChange={e => setTempK(+e.target.value)}
                style={{ width: "100%", accentColor: "#00e5ff" }} />
              <div style={{ display: "flex", justifyContent: "space-between", fontSize: 9, color: "#2a4a60" }}>
                <span>77K criogénico</span><span>500K caliente</span>
              </div>
            </div>
            <div>
              <label style={{ fontSize: 10, color: "#6a9ab0", display: "block", marginBottom: 6 }}>
                SHOTS: <span style={{ color: "#39ff14" }}>{shots.toLocaleString()}</span>
              </label>
              <input type="range" min="256" max="16384" step="256" value={shots} onChange={e => setShots(+e.target.value)}
                style={{ width: "100%", accentColor: "#39ff14" }} />
              <div style={{ display: "flex", justifyContent: "space-between", fontSize: 9, color: "#2a4a60" }}>
                <span>256</span><span>16,384</span>
              </div>
            </div>
          </div>
          <button onClick={execute} disabled={running} style={{
            marginTop: 14, width: "100%", padding: "11px",
            background: running ? "#0a1a2a" : "linear-gradient(90deg, #003d5c, #005c8a)",
            border: `1px solid ${running ? "#0a2a40" : "#00e5ff"}`, borderRadius: 8,
            color: running ? "#355a70" : "#00e5ff", fontSize: 12,
            fontFamily: "monospace", letterSpacing: 3,
            cursor: running ? "not-allowed" : "pointer",
            boxShadow: running ? "none" : "0 0 10px #00e5ff33", transition: "all 0.3s",
          }}>
            {running ? "⚙️  EJECUTANDO..." : "▶  EJECUTAR SIMULACIÓN"}
          </button>
        </div>

        {/* Grid principal */}
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 14 }}>
          {/* Izquierda: Visualización */}
          <div style={{ background: "#050f1e", border: "1px solid #0a2a40", borderRadius: 10, padding: 18 }}>
            <div style={{ display: "flex", gap: 6, marginBottom: 14 }}>
              {[["bloch","ESFERA BLOCH"],["phase","DIAGRAMA FASE"],["circuit","CIRCUITO"]].map(([id,lbl]) => (
