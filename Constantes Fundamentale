              ))}
            </div>

            {tab === "bloch" && (
              <div>
                <div style={{ display: "flex", justifyContent: "center", marginBottom: 6 }}>
                  <EntangledBlochSphere tick={tick} idealState={result?.idealState} trails={trailsRef} />
                </div>
                <div style={{ fontSize: 8, color: "#355a70", textAlign: "center", marginBottom: 10 }}>
                  Q1/Q2/Q3 desfase 120° · Esfera de Bloch estándar
                </div>
                <div style={{ borderTop: "1px solid #0a2a40", paddingTop: 10 }}>
                  <div style={{ fontSize: 9, color: "#6a9ab0", letterSpacing: 3, marginBottom: 8 }}>LECTURAS EN TIEMPO REAL</div>
                  {liveVec.map((v) => (
                    <div key={v.id} style={{ display: "flex", justifyContent: "space-between", marginBottom: 5, alignItems: "center" }}>
                      <span style={{ fontSize: 10, color: v.color, fontWeight: 700, width: 22 }}>{v.id}</span>
                      <span style={{ fontSize: 9, color: "#4a7a90" }}>θ={v.theta.toFixed(3)}</span>
                      <span style={{ fontSize: 9, color: "#4a7a90" }}>φ={v.phi.toFixed(3)}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {tab === "phase" && (
              <div>
                <div style={{ display: "flex", justifyContent: "center", marginBottom: 8 }}>
                  <PhaseDiagram tick={tick} />
                </div>
                <div style={{ borderTop: "1px solid #0a2a40", paddingTop: 10 }}>
                  <div style={{ fontSize: 9, color: "#6a9ab0", letterSpacing: 3, marginBottom: 8 }}>FASES ACTUALES (÷ φ)</div>
                  {QUBITS_DEF.map((q) => {
                    const a = ((tick * PHI_FRAMES + q.phase) / PHI) % (2*Math.PI);
                    return (
                      <div key={q.id} style={{ display: "flex", justifyContent: "space-between", marginBottom: 5 }}>
                        <span style={{ fontSize: 10, color: q.color }}>{q.id} Δ{(q.phase*180/Math.PI).toFixed(0)}°</span>
                        <span style={{ fontSize: 10, color: "#c8e6f5" }}>{(a*180/Math.PI).toFixed(2)}°</span>
                      </div>
                    );
                  })}
                  <div style={{ marginTop: 8, fontSize: 9, color: "#355a70" }}>
                    PHI_FRAMES={PHI_FRAMES.toFixed(4)} · frame={tick}
                  </div>
                </div>
              </div>
            )}

            {tab === "circuit" && (
              <div>
                <div style={{ fontSize: 9, color: "#6a9ab0", letterSpacing: 3, marginBottom: 10 }}>CIRCUITO PRINCIPAL</div>
                <div style={{ display: "flex", alignItems: "center", marginBottom: 16, flexWrap: "wrap", gap: 2 }}>
                  {[
                    { l:"|0⟩", w:30, bc:"none", c:"#c8e6f5", bg:"transparent" },
                    { l:"──", w:20, bc:"none", c:"#0a3a5a", bg:"transparent" },
                    { l:`RZ\n${GOLDEN_ANGLE_DEG.toFixed(1)}°`, w:54, bc:"1px solid #39ff1477", c:"#39ff14", bg:"#002a10", r:5 },
                    { l:"──", w:20, bc:"none", c:"#0a3a5a", bg:"transparent" },
                    { l:"H", w:34, bc:"1px solid #00e5ff77", c:"#00e5ff", bg:"#001a2e", r:5 },
                    { l:"──", w:20, bc:"none", c:"#0a3a5a", bg:"transparent" },
                    { l:"⊗", w:34, bc:"1px solid #ff6b3577", c:"#ff6b35", bg:"#2a1000", r:17 },
                  ].map((g,i) => (
                    <div key={i} style={{
                      width: g.w, minWidth: g.w, height: g.bc!=="none"?36:"auto",
                      display:"flex", alignItems:"center", justifyContent:"center",
                      background: g.bg, border: g.bc, borderRadius: g.r||0,
                      color: g.bc!=="none"?g.c:"#0a3a5a", textAlign:"center", whiteSpace:"pre",
                      fontSize: (g.l||"").includes("\n")?8:11,
                      boxShadow: g.bc!=="none"?`0 0 5px ${g.c}33`:"none",
                    }}>{g.l}</div>
                  ))}
                </div>
                <div style={{ fontSize: 9, color: "#6a9ab0", letterSpacing: 3, marginBottom: 8 }}>MOTOR SIMPÁTICO</div>
                {QUBITS_DEF.map((q) => (
                  <div key={q.id} style={{ display: "flex", alignItems: "center", marginBottom: 6, gap: 6 }}>
                    <span style={{ fontSize: 10, color: q.color, width: 22 }}>{q.id}</span>
                    <div style={{ flex:1, height:1, background: q.color, opacity:0.25 }} />
                    <div style={{ padding:"2px 7px", border:`1px solid ${q.color}55`, borderRadius:4, fontSize:9, color:q.color, background:`${q.color}0e` }}>
                      Δφ={+(q.phase*180/Math.PI).toFixed(0)}° ÷ φ
                    </div>
                    <div style={{ flex:1, height:1, background: q.color, opacity:0.25 }} />
                  </div>
                ))}
                <div style={{ marginTop:10, fontSize:9, color:"#355a70", borderTop:"1px solid #0a2a40", paddingTop:8 }}>
                  <div>Ruido de Pauli: p_error = min(0.5, T/1000)</div>
                  <div>Fidelidad = ⟨ψ|ρ|ψ⟩  |  Física rigurosa</div>
                </div>
              </div>
            )}
          </div>

          {/* Derecha: Resultados */}
          <div style={{
            background: "#050f1e", border: "1px solid #0a2a40", borderRadius: 10, padding: 18,
            display: "flex", flexDirection: "column", gap: 11,
          }}>
            <div style={{ fontSize: 10, color: "#00e5ff", letterSpacing: 3 }}>RESULTADOS DE MEDICIÓN</div>

            {result ? (
              <>
                <div style={{
                  background: "#020c18",
                  border: `1px solid ${result.fidelity > 0.99 ? "#39ff14" : "#ff6b35"}`,
                  borderRadius: 8, padding: "11px 13px", textAlign: "center",
                  boxShadow: `0 0 12px ${result.fidelity > 0.99 ? "#39ff1418" : "#ff6b3518"}`,
                }}>
                  <div style={{ fontSize: 9, color: "#6a9ab0", letterSpacing: 3, marginBottom: 2 }}>FIDELIDAD CUÁNTICA</div>
                  <div style={{ fontSize: 19, fontWeight: 900, fontFamily: "monospace",
                    color: result.fidelity > 0.99 ? "#39ff14" : "#ff6b35",
                    textShadow: `0 0 10px ${result.fidelity > 0.99 ? "#39ff14" : "#ff6b35"}`,
                  }}>
                    {result.fidelity.toFixed(10)}
                  </div>
                  <div style={{ fontSize: 9, color: "#355a70", marginTop: 2 }}>
                    {result.fidelity > 0.99 ? "✓ Dentro del corredor áureo" : "⚠ Desviación por ruido"}
                  </div>
                </div>

                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8 }}>
                  {[
                    ["CONSUMO F25 (estético)", `${result.recursos.toFixed(4)} L`, "#ff6b35"],
                    ["ÁNGULO MAESTRO", `${GOLDEN_ANGLE_DEG.toFixed(3)}°`, "#39ff14"],
                    ["p_error (ruido)", `${result.p_error.toFixed(4)}`, "#00e5ff"],
                  ].map(([label, val, c]) => (
                    <div key={label} style={{ background: "#020c18", border: "1px solid #0a2a40", borderRadius: 8, padding: "9px 11px" }}>
                      <div style={{ fontSize: 9, color: "#6a9ab0", letterSpacing: 1 }}>{label}</div>
                      <div style={{ fontSize: 15, color: c, fontWeight: 700, marginTop: 2 }}>{val}</div>
                    </div>
                  ))}
                </div>

                <div style={{ background: "#020c18", border: "1px solid #0a2a40", borderRadius: 8, padding: "9px 11px" }}>
                  <div style={{ fontSize: 9, color: "#6a9ab0", letterSpacing: 2, marginBottom: 7 }}>DISTRIBUCIÓN</div>
                  <ProbBar label="|0⟩ ideal" value={result.p0_ideal} color="#00e5ff" />
                  <ProbBar label="|1⟩ ideal" value={result.p1_ideal} color="#00e5ff" />
                  <ProbBar label="|0⟩ shots" value={result.prob0} color="#39ff14" />
                  <ProbBar label="|1⟩ shots" value={result.prob1} color="#39ff14" />
                </div>

                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8 }}>
                  {[["0","#00e5ff"],["1","#ff6b35"]].map(([bit,col]) => (
                    <div key={bit} style={{ background:"#020c18", border:`1px solid ${col}44`, borderRadius:8, padding:"8px", textAlign:"center" }}>
                      <div style={{ fontSize:9, color:"#6a9ab0" }}>|{bit}⟩ COUNTS</div>
                      <div style={{ fontSize:17, color:col, fontWeight:700, marginTop:2 }}>{result.counts[bit].toLocaleString()}</div>
                      <div style={{ fontSize:9, color:"#355a70" }}>/ {shots.toLocaleString()}</div>
                    </div>
                  ))}
                </div>

                <div style={{ background: "#020c18", border: "1px solid #0a2a40", borderRadius: 8, padding: "9px 11px" }}>
                  <div style={{ fontSize: 9, color: "#6a9ab0", letterSpacing: 2, marginBottom: 7 }}>ENTRELAZAMIENTO LIVE</div>
                  {liveVec.map((v) => {
                    const a = ((tick * PHI_FRAMES + v.phase) / PHI) % (2*Math.PI);
                    const pct = ((Math.sin(a)+1)/2*100).toFixed(0);
                    return (
                      <div key={v.id} style={{ display: "flex", alignItems: "center", marginBottom: 5, gap: 6 }}>
                        <span style={{ fontSize: 10, color: v.color, width: 22, fontWeight: 700 }}>{v.id}</span>
                        <div style={{ flex:1, height:4, borderRadius:2, background:"#0a1a2a", overflow:"hidden" }}>
                          <div style={{ width:`${pct}%`, height:"100%", background: v.color, opacity:0.75, transition:"width 0.06s" }} />
                        </div>
                        <span style={{ fontSize: 9, color: "#4a7a90", width:46, textAlign:"right" }}>
                          {(a*180/Math.PI).toFixed(1)}°
                        </span>
                      </div>
                    );
                  })}
                </div>
              </>
            ) : (
              <div style={{ flex:1, display:"flex", alignItems:"center", justifyContent:"center", color:"#355a70", fontSize:12 }}>
                Esperando ejecución...
              </div>
            )}
          </div>
        </div>

        {/* Consola */}
        <div style={{ background: "#020c18", border: "1px solid #0a2a40", borderRadius: 10, padding: 14 }}>
          <div style={{ fontSize: 10, color: "#39ff14", letterSpacing: 3, marginBottom: 8 }}>CONSOLA DE EJECUCIÓN</div>
          <div ref={logRef} style={{ height: 132, overflowY: "auto", fontFamily: "monospace", fontSize: 10, lineHeight: 1.7 }}>
            {log.map((line, i) => (
              <div key={i} style={{
                color: line.includes("COMPLETADA") ? "#39ff14"
                  : line.includes("Fidelidad") ? "#00e5ff"
                  : line.includes("ENTRELAZADOS") ? "#ff3b3b"
                  : line.includes("⚠") ? "#ff6b35"
                  : "#4a8a70",
              }}>{line}</div>
            ))}
            {running && <div style={{ color: "#00e5ff", opacity: pulseOp }}>█</div>}
          </div>
        </div>

        <div style={{ textAlign: "center", fontSize: 9, color: "#1a3a50", letterSpacing: 2 }}>
          MOTOR SIMPÁTICO · 3 QUBITS · φ = {PHI.toFixed(8)} · Física corregida (Pauli noise)
        </div>
      </div>
    </div>
  );
}
